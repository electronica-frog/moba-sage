{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/tierlist-feed.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/patches-feed.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/activity-feed.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=60, stale-while-revalidate=300" }
      ]
    }
  ]
}
